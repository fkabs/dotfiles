{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "permission": {
    "*": "ask",
    "read": {
      "*": "ask",
      "~/.config/opencode/**": "allow",
      "/tmp/**": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}
